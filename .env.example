# Smart Takaful & Consultation System - local env template
# Copy to `.env` and fill in real values. The `.env` file is gitignored and
# auto-loaded at startup via spring-dotenv.

# --- Spring profile ---
# `dev`  -> in-memory H2, no external creds required (offline).
# `prod` -> real Supabase Postgres via the transaction pooler (below).
SPRING_PROFILES_ACTIVE=prod

# --- Supabase Postgres (Transaction pooler, port 6543) ------------------------
# 1. Find the exact pooler host for your project in the Supabase dashboard:
#    Project Settings -> Database -> Connection string -> "Transaction pooler".
#    Example host: aws-1-ap-northeast-1.pooler.supabase.com
# 2. Username is `postgres.<project-ref>`. Ref for this project is already
#    filled in below.
# 3. Password is the database password you set when creating the project
#    (Project Settings -> Database -> Database password). If you forgot it,
#    reset it there - the publishable/anon API key will NOT work here.
# ------------------------------------------------------------------------------
SPRING_DATASOURCE_URL=jdbc:postgresql://aws-1-ap-northeast-1.pooler.supabase.com:6543/postgres
SPRING_DATASOURCE_USERNAME=postgres.onempwqinsaybmmdudjf
SPRING_DATASOURCE_PASSWORD=

# --- App URLs ---
# Required for ToyyibPay return/callback URLs in sandbox/live mode.
APP_BASE_URL=https://your-railway-app.up.railway.app

# --- Google Gemini (chatbot) ---
# Free-tier API key from Google AI Studio: https://aistudio.google.com/apikey
# Used by /api/chat to ground Takaful answers via lightweight RAG.
GEMINI_API_KEY=

# --- Contact form email ---
# POST /contact sends site enquiries to CONTACT_RECIPIENT.
# Delivery options:
# - auto: SMTP first, then Resend if configured, then FormSubmit fallback
# - resend: HTTPS email API, recommended for Railway because SMTP ports may be blocked
# - smtp: authenticated mailbox SMTP
# - formsubmit: simple forwarding fallback
CONTACT_DELIVERY=resend
CONTACT_RECIPIENT=wanersyadd@gmail.com
CONTACT_FROM=onboarding@resend.dev
RESEND_API_KEY=
RESEND_BASE_URL=https://api.resend.com
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_SMTP_STARTTLS_ENABLE=true
CONTACT_FORMSUBMIT_ENABLED=true
CONTACT_FORMSUBMIT_BASE_URL=https://formsubmit.co/ajax

# --- ToyyibPay quotation payments ---
# mock = local simulated gateway, sandbox = dev.toyyibpay.com, live = toyyibpay.com
TOYYIBPAY_MODE=live
TOYYIBPAY_SECRET_KEY=
TOYYIBPAY_CATEGORY_CODE=rvr7gy3p
TOYYIBPAY_BASE_URL=https://toyyibpay.com

# --- Private file storage ---
# local    = files saved to LOCAL_UPLOAD_DIR (offline dev only).
# supabase = files stored in the private Supabase Storage bucket (matches production,
#            and lets you see the real product images/brochures).
# To mirror production, set supabase and fill SUPABASE_SERVICE_ROLE_KEY below.
FILE_STORAGE_MODE=supabase
LOCAL_UPLOAD_DIR=uploads
SUPABASE_URL=https://onempwqinsaybmmdudjf.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=takaful-private

# --- Local starter data ---
# Dev-only. When true and the products table is empty, inserts starter dynamic products.
# Keep false for Railway/prod; create real products through the admin CRUD instead.
DEMO_SEED_ENABLED=false

# --- Admin (Spring Security) ---
# Required in prod/Railway. Dev defaults to admin/password if unset.
ADMIN_USERNAME=wanersyadd
ADMIN_PASSWORD=
